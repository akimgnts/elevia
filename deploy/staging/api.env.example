# Copy to deploy/staging/api.env before running docker compose.
# Do not commit the real file.

# Optional now, but required for LLM-backed features.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Safe defaults for private staging.
ENV=staging
DEBUG=0
ELEVIA_DEV=0
ELEVIA_DEV_TOOLS=0
ELEVIA_INBOX_USE_VIE_FIXTURES=0
ELEVIA_EMBEDDINGS_LOCAL=0

# Optional integrations for later sync/scraping jobs.
ONET_API_KEY=
ONET_API_BASE_URL=

