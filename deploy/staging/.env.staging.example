# Copy to deploy/staging/.env.staging before running docker compose.

# Compose project name shown by docker.
COMPOSE_PROJECT_NAME=elevia-staging

# Use a real domain here for automatic HTTPS with Caddy.
# If you do not have a domain yet, keep :80 for private HTTP staging on the VPS IP.
APP_SITE_ADDRESS=:80

# Keep staging private by default.
STAGING_BASIC_AUTH_USER=staging
STAGING_BASIC_AUTH_HASH=

# Persistent host directory on the VPS.
ELEVIA_STATE_DIR=/opt/elevia-staging/state

