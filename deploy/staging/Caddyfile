{
	admin off
}

{$APP_SITE_ADDRESS} {
	encode zstd gzip

	basicauth /* {
		{$STAGING_BASIC_AUTH_USER} {$STAGING_BASIC_AUTH_HASH}
	}

	handle_path /api/* {
		reverse_proxy api:8000
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

